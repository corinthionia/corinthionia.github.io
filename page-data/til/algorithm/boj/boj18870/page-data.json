/span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span></code></pre></div>","frontmatter":{"title":"[Node.js | JavaScript] 백준 18870 좌표 압축 코드","summary":"[실버2] 백준 18870 좌표 압축 Node.js JavaScript 코드","date":"November 06, 2022","categories":["TIL","algorithm"],"thumbnail":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/png;base64,"},"images":{"fallback":{"src":"/static/b393dbbc1c7fc0366ca63f23435508f0/a0287/boj18870.png","srcSet":"/static/b393dbbc1c7fc0366ca63f23435508f0/6ecb6/boj18870.png 30w,\n/static/b393dbbc1c7fc0366ca63f23435508f0/43a9d/boj18870.png 60w,\n/static/b393dbbc1c7fc0366ca63f23435508f0/a0287/boj18870.png 120w,\n/static/b393dbbc1c7fc0366ca63f23435508f0/f5f72/boj18870.png 240w","sizes":"(min-width: 120px) 120px, 100vw"},"sources":[{"srcSet":"/static/b393dbbc1c7fc0366ca63f23435508f0/2b147/boj18870.webp 30w,\n/static/b393dbbc1c7fc0366ca63f23435508f0/caa3b/boj18870.webp 60w,\n/static/b393dbbc1c7fc0366ca63f23435508f0/b15f9/boj18870.webp 120w,\n/static/b393dbbc1c7fc0366ca63f23435508f0/b5014/boj18870.webp 240w","type":"image/webp","sizes":"(min-width: 120px) 120px, 100vw"}]},"width":120,"height":120}},"publicURL":"/static/b393dbbc1c7fc0366ca63f23435508f0/boj18870.png"}}}}]},"file":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/0a26d336dc62306ceb50b7ed12e4aefc/bbf83/profile-image.jpg","srcSet":"/static/0a26d336dc62306ceb50b7ed12e4aefc/a8e5a/profile-image.jpg 30w,\n/static/0a26d336dc62306ceb50b7ed12e4aefc/bea51/profile-image.jpg 60w,\n/static/0a26d336dc62306ceb50b7ed12e4aefc/bbf83/profile-image.jpg 120w,\n/static/0a26d336dc62306ceb50b7ed12e4aefc/7793c/profile-image.jpg 240w","sizes":"(min-width: 120px) 120px, 100vw"},"sources":[{"srcSet":"/static/0a26d336dc62306ceb50b7ed12e4aefc/2b147/profile-image.webp 30w,\n/static/0a26d336dc62306ceb50b7ed12e4aefc/caa3b/profile-image.webp 60